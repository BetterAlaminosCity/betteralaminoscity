{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "city-statistics.schema.json",
  "type": "object",
  "required": ["lastUpdated", "source", "totalPopulation", "barangays", "economicIndicators"],
  "properties": {
    "lastUpdated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "source": { "type": "string", "minLength": 1 },
    "totalPopulation": { "type": "number", "minimum": 0 },
    "barangays": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "population"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "population": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "economicIndicators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
