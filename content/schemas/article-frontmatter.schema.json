{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "article-frontmatter.schema.json",
  "type": "object",
  "required": ["title", "description"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "lastUpdated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "office": { "type": "string", "minLength": 1 },
    "classification": { "type": "string", "enum": ["Simple", "Complex", "Highly Technical"] },
    "transactionType": { "type": "string", "minLength": 1 },
    "whoMayAvail": { "type": "string", "minLength": 1 },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "whereToSecure"],
        "properties": {
          "item": { "type": "string", "minLength": 1 },
          "whereToSecure": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["clientStep", "agencyAction", "fee", "processingTime"],
        "properties": {
          "phase": { "type": "string" },
          "clientStep": { "type": "string", "minLength": 1 },
          "agencyAction": { "type": "string", "minLength": 1 },
          "fee": { "type": "string", "minLength": 1 },
          "processingTime": { "type": "string", "minLength": 1 },
          "personResponsible": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "totalProcessingTime": { "type": "string", "minLength": 1 },
    "totalFees": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
