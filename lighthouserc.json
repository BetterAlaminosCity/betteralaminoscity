{
  "ci": {
    "collect": {
      "startServerCommand": "npx tsx scripts/lhci-server.ts",
      "startServerReadyPattern": "lhci static server listening",
      "url": [
        "http://localhost:4173/index.html",
        "http://localhost:4173/services/index.html",
        "http://localhost:4173/government/index.html",
        "http://localhost:4173/search/index.html"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.85 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
